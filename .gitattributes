# Enforce LF line endings for all text files
* text=auto eol=lf

# Explicitly mark common file types as text
*.php text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.sh text eol=lf
*.css text eol=lf
*.js text eol=lf
*.html text eol=lf
*.twig text eol=lf
*.neon text eol=lf
*.dist text eol=lf
*.lock text eol=lf

# Binary files - don't touch
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.gz binary
*.tar binary
*.phar binary

# Test fixture that must keep CRLF line endings
tests/Fixtures/sse-simple-text-crlf.txt -text

# Exclude from distribution archives (composer install / packagist)
/.github/               export-ignore
/docs/                  export-ignore
/tests/                 export-ignore
/scripts/               export-ignore
CLAUDE.md               export-ignore
CONTRIBUTING.md         export-ignore
CHANGELOG.md            export-ignore
.editorconfig           export-ignore
.php-cs-fixer.php       export-ignore
infection.json5         export-ignore
phpmd.xml               export-ignore
phpstan.neon            export-ignore
phpunit.xml             export-ignore
